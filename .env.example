# Telegram: create a bot in @BotFather with /newbot and copy the token.
BOT_TOKEN=123456:replace_me
# chat_id is usually detected by the setup wizard after you send /start to the bot.
ALLOWED_CHAT_IDS=123456789
ADMIN_CHAT_IDS=
ACCESS_APPROVALS_ENABLED=true
LOG_LEVEL=INFO
TZ=Europe/Moscow
BOT_TIMEZONE=Europe/Moscow
MAX_TORRENT_FILE_MB=20
STATE_DIR=/data
# DSM URL visible from the container. On Synology Docker, host.docker.internal
# is mapped by compose.yaml to the NAS host gateway.
DS_URL=https://192.168.1.103:5001
DS_ACCOUNT=tg_bot_ds
DS_PASSWORD=replace_me
# Download Station destination shared folder, usually "video" or "downloads".
DS_DESTINATION=video
DS_VERIFY_SSL=false
TRACKERS_MODE=auto
TRACKERS_URL=https://raw.githubusercontent.com/ngosang/trackerslist/master/trackers_best.txt
TRACKERS_MAX=20
TRACKERS_CACHE_TTL_HOURS=24
TRACKERS_BACKGROUND_ENABLED=true
TRACKERS_BACKGROUND_INTERVAL_SECONDS=180
TASK_NOTIFICATIONS_ENABLED=true
TASK_NOTIFICATION_STATUSES=finished,seeding,error
TASK_NOTIFY_EXTERNAL_TASKS=false
NOTIFY_CHAT_IDS=
AUTO_DELETE_FINISHED_AFTER_HOURS=24
AUTO_DELETE_FINISHED_STATUSES=finished
MAGNET_POLL_ATTEMPTS=8
MAGNET_POLL_INTERVAL_SECONDS=1.5
DS_RETRY_ATTEMPTS=3
DS_RETRY_DELAY=2.0
# Rutracker (optional): login/password of a rutracker.org account.
# If captcha appears, log in with a browser from the same IP and solve it once.
RUTRACKER_USERNAME=
RUTRACKER_PASSWORD=
RUTRACKER_MAX_RESULTS=50
# Kinopoisk API key: kinopoiskapiunofficial.tech → account → API key.
KINOPOISK_API_KEY=
# TMDB API Read Access Token: themoviedb.org → Settings → API.
# Use the long Bearer token, not the short API key.
TMDB_API_TOKEN=
MOVIE_DISCOVERY_ENABLED=true
MOVIE_DISCOVERY_INTERVAL_HOURS=6
MOVIE_DISCOVERY_CACHE_FILE=/data/movie_discovery.json
MOVIE_DISCOVERY_SETTINGS_FILE=/data/movie_discovery_settings.json
MOVIE_DISCOVERY_DEBUG_FILE=/data/movie_discovery_debug.json
MOVIE_DISCOVERY_RUTRACKER_TM=32
MOVIE_DISCOVERY_JACKETT_REQUIRE_DATE=true
MOVIE_DISCOVERY_JACKETT_MAX_AGE_DAYS=32
MOVIE_DISCOVERY_LIMIT=30
MOVIE_DISCOVERY_MIN_KP_RATING=6.0
MOVIE_DISCOVERY_QUALITIES=1080p
# Plex Media Server (optional — enables ✅ badge in /new, pre-download check, appearance notifications)
PLEX_URL=
PLEX_TOKEN=
PLEX_MOVIE_SECTION=
# Optional: own redirect page that converts https URL to plex:// custom scheme
# so iOS/Android Plex apps open natively from Telegram buttons.
# If unset → buttons use https://app.plex.tv/desktop (opens Plex Web in browser).
# If set → button → your URL?key=...&server=... → page JS does location.href="plex://..."
# Example: PLEX_DEEPLINK_BASE_URL=https://nas.example.com/plex.html
PLEX_DEEPLINK_BASE_URL=
# Optional: Plex webhook endpoint in LAN. Add this URL in Plex:
# http://<NAS_IP>:8099/plex/webhook?token=<PLEX_WEBHOOK_TOKEN>
PLEX_WEBHOOK_ENABLED=false
PLEX_WEBHOOK_HOST=0.0.0.0
PLEX_WEBHOOK_PORT=8099
PLEX_WEBHOOK_TOKEN=
PLEX_WEBHOOK_DEBOUNCE_SECONDS=10
SUBSCRIPTION_CHECK_INTERVAL_HOURS=6
# Jackett (optional — broad search and fallback when Rutracker is unavailable).
# JACKETT_URL is the Jackett web URL, usually http://<NAS_IP>:9117.
# JACKETT_API_KEY is shown at the top of Jackett Dashboard.
JACKETT_URL=
JACKETT_API_KEY=
JACKETT_INDEXERS=all
JACKETT_MAX_RESULTS=20
JACKETT_FETCH_LIMIT=100
JACKETT_SEARCH_TIMEOUT_SECONDS=90
JACKETT_WARMUP_ENABLED=true
JACKETT_WARMUP_INTERVAL_SECONDS=900
JACKETT_WARMUP_QUERY=1080p
JACKETT_WARMUP_INDEXERS=auto
JACKETT_WARMUP_BATCH_SIZE=3
# Pending download queue (optional — retries failed downloads in the background)
PENDING_DOWNLOADS_ENABLED=true
PENDING_DOWNLOADS_INTERVAL_SECONDS=300
PENDING_DOWNLOADS_TTL_HOURS=24
SERIES_BULK_JOBS_FILE=/data/series_bulk_jobs.json
SERIES_CONTINUE_TOTALS_FILE=/data/series_continue_totals.json
SERIES_CONTINUE_HIDDEN_FILE=/data/series_continue_hidden.json
# Storage budget (optional — shows /admin «📀 Хранилище» block).
# The block appears automatically when /storage exists inside the container
# (bind-mount in compose.yaml). This variable only tunes the alert threshold.
STORAGE_ALERT_PERCENT=90
# Voice search via OpenAI Whisper API (optional; pay-per-use, no subscription).
# Empty OPENAI_API_KEY → voice messages are ignored (feature disabled).
# Set a hard monthly limit at https://platform.openai.com/settings/limits
OPENAI_API_KEY=
VOICE_SEARCH_ENABLED=true
VOICE_MAX_SECONDS=30
# GPT-powered precision improvements (KP match validation, did-you-mean suggestions).
# Reuses OPENAI_API_KEY above. Default model is the cheapest viable; tweak only if needed.
GPT_ENABLED=true
GPT_MODEL=gpt-4o-mini
# YouTube download inbox (optional; disabled by default).
# Before enabling: create NAS shared folder /volume1/youtube, grant bot write
# access and Plex read access, then add it as a separate Plex "Other Videos"
# library named YouTube.
YOUTUBE_DOWNLOADS_ENABLED=false
YOUTUBE_NAS_PATH=/volume1/youtube
YOUTUBE_DOWNLOAD_DIR=/youtube_storage
YOUTUBE_DOWNLOADS_FILE=/data/youtube_downloads.json
YOUTUBE_MAX_DURATION_MINUTES=300
YOUTUBE_MAX_HEIGHT=1080
YOUTUBE_MAX_PARALLEL=1
# 0 means no hard queue limit; one active download is still enforced.
YOUTUBE_MAX_QUEUE_SIZE=0
YOUTUBE_MAX_QUEUE_PER_CHAT=0
YOUTUBE_MIN_FREE_GB=5
YOUTUBE_PLEX_SECTION=
YOUTUBE_PLEX_LIBRARY_NAME=YouTube
YOUTUBE_PLEX_REFRESH_AFTER_DOWNLOAD=false
YOUTUBE_PLEX_POLL_AFTER_DOWNLOAD=true
YOUTUBE_PLEX_POLL_ATTEMPTS=20
YOUTUBE_PLEX_POLL_INTERVAL_SECONDS=30
